{
  "schema_version": 1,
  "name": "livestorm",
  "display_name": "Livestorm",
  "auth_type": "api_key",
  "flow": "api_key_prompt",
  "api_key": {
    "input_mode": "prompt",
    "header_name": "Authorization",
    "header_prefix": "Bearer",
    "env_var": "LIVESTORM_API_TOKEN"
  },
  "export": {
    "env": {
      "api_key": "LIVESTORM_API_TOKEN"
    }
  }
}
