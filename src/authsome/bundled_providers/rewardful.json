{
  "schema_version": 1,
  "name": "rewardful",
  "display_name": "Rewardful",
  "auth_type": "api_key",
  "flow": "api_key_prompt",
  "api_key": {
    "input_mode": "prompt",
    "header_name": "Authorization",
    "header_prefix": "Bearer",
    "env_var": "REWARDFUL_API_KEY"
  },
  "export": {
    "env": {
      "api_key": "REWARDFUL_API_KEY"
    }
  }
}
