{
  "schema_version": 1,
  "name": "mailchimp",
  "display_name": "Mailchimp",
  "auth_type": "api_key",
  "flow": "api_key_prompt",
  "api_key": {
    "input_mode": "prompt",
    "header_name": "Authorization",
    "header_prefix": "Bearer",
    "env_var": "MAILCHIMP_API_KEY"
  },
  "export": {
    "env": {
      "api_key": "MAILCHIMP_API_KEY"
    }
  }
}
